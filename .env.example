# API base URL — the Vite dev server proxies /api to this target.
# In production, set to the actual msgvault server URL.
VITE_API_URL=http://localhost:8080

# WARNING: VITE_API_KEY is inlined into the production JS bundle at build time.
# NEVER set this for internet-facing deployments — the key will be visible in source.
# Only use for local/LAN development.
# VITE_API_KEY=
